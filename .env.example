# Railbase — example environment file.
#
# Copy to `.env` (gitignored), uncomment the keys you need, fill in
# values for your install. Process env vars take precedence over this
# file, so `RAILBASE_DSN=... ./railbase serve` will override the DSN
# below for a one-off run without editing the file.
#
# CLI flags > process env > .env file > built-in defaults.
#
# Railbase also reads `<RAILBASE_DATA_DIR>/.env` after this file, so
# you can keep per-instance secrets next to `pb_data/` if you prefer.

# ─── HTTP server ────────────────────────────────────────────────────

# Bind address. Default :8095 (IANA-unassigned, no default-daemon
# collision on Linux/Windows/macOS). Common overrides:
#   :8090   PocketBase compatibility (PB's port)
#   :443    Behind a TLS-terminating proxy bind to localhost:8095 instead
# RAILBASE_HTTP_ADDR=:8095

# Graceful shutdown deadline. Connections held open longer are dropped.
# RAILBASE_SHUTDOWN_GRACE=15s

# ─── Database ───────────────────────────────────────────────────────

# Postgres DSN. Required in production. In dev (RAILBASE_PROD unset),
# leave blank to fall back to:
#   - embedded postgres (if binary built with `-tags embed_pg`), OR
#   - first-run setup wizard (production binaries)
# Format: postgres://user:pass@host:port/dbname?sslmode=require
# RAILBASE_DSN=postgres://railbase:railbase@localhost:5432/railbase?sslmode=disable

# ─── Filesystem layout ──────────────────────────────────────────────

# Where uploaded files, hooks, embedded-PG data, .secret, .dsn live.
# RAILBASE_DATA_DIR=./pb_data

# Where pb_hooks/*.pb.js files live.
# RAILBASE_HOOKS_DIR=./pb_hooks

# Where static assets are served from at "/". Empty disables.
# RAILBASE_PUBLIC_DIR=

# ─── Mode flags ─────────────────────────────────────────────────────

# Production mode: disables embedded-PG, hot-reload watchers, verbose
# error pages, weakened CSRF / anti-bot defaults.
# RAILBASE_PROD=false

# Dev mode: pretty logging + admin-UI dev proxy. Mutually exclusive
# with RAILBASE_PROD.
# RAILBASE_DEV=false

# Force-enable embedded Postgres. Only effective if the binary was
# built with `-tags embed_pg` (see `make build-embed`). Refused
# with RAILBASE_PROD=true.
# RAILBASE_EMBED_POSTGRES=false

# ─── Compatibility ──────────────────────────────────────────────────

# PocketBase URL-shape compatibility:
#   strict — PB-shape URLs only
#   native — Railbase-shape URLs only
#   both   — both (default)
# RAILBASE_PB_COMPAT=both

# ─── Logging ────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
# RAILBASE_LOG_LEVEL=info

# Log format: json (default; for ingestion by Loki / Datadog / etc.)
# or text (human-readable in a terminal).
# RAILBASE_LOG_FORMAT=json

# ─── Optional: rate-limit / security overrides ──────────────────────

# Anti-bot middleware (production-default ON, dev-default OFF).
# Set to true to test honeypot behaviour during dev.
# RAILBASE_ANTIBOT_ENABLED=

# Trusted proxy CIDRs for X-Forwarded-For walking (CSV).
# Empty (default) = do not trust any proxy's X-Forwarded-For header.
# RAILBASE_TRUSTED_PROXIES=

# ─── Mail (mailer service) ──────────────────────────────────────────

# These are also configurable via the admin Settings UI; values here
# are picked up at boot time. The setup wizard writes a one-time
# `mailer.configured_at` flag so the wizard doesn't reprompt.
# RAILBASE_MAILER_DRIVER=smtp
# RAILBASE_MAILER_FROM=Admin <admin@example.com>
# RAILBASE_MAILER_SMTP_HOST=smtp.example.com
# RAILBASE_MAILER_SMTP_PORT=587
# RAILBASE_MAILER_SMTP_USER=...
# RAILBASE_MAILER_SMTP_PASSWORD=...
# RAILBASE_MAILER_SMTP_TLS=starttls

# ─── Admin URL (used in outbound email links) ───────────────────────

# Public URL where the admin UI is reachable. Used as the base for
# password-reset links, welcome emails, new-device notices. Defaults
# to http://localhost:8095/_/ which is fine for local dev; set this
# explicitly behind a TLS-terminating proxy.
# RAILBASE_ADMIN_URL=https://admin.example.com/_/
