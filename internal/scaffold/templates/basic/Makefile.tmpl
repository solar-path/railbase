# Makefile for {{.ProjectName}} — generated by `railbase init`.
#
# Dev defaults to `-tags embed_pg` so the embedded-postgres path
# (RAILBASE_EMBED_POSTGRES=true, `migrate diff` against a local PG, etc.)
# works out of the box on a fresh checkout — no host Postgres required.
#
# For production / release binaries use `make build-prod`, which drops the
# tag and produces a slim binary that connects only to an external
# RAILBASE_DSN. The dev tag adds ~50 MB to the binary; the prod variant
# does not.
#
# FEEDBACK #6 / #27 — scaffold ships embed_pg-by-default so the
# documented `migrate diff` and `RAILBASE_EMBED_POSTGRES=true` paths
# don't surprise embedders with "embedded postgres not compiled in".

.PHONY: help dev build build-prod migrate-diff migrate-up clean

BIN      ?= bin/{{.ProjectName}}
BIN_PROD ?= bin/{{.ProjectName}}-prod
TAGS_DEV ?= embed_pg

# `make` with no args prints help — less surprising than building a
# 200 MB binary the first time someone runs it.
.DEFAULT_GOAL := help

help: ## Show this help.
	@grep -E '^[a-zA-Z_-]+:.*?## ' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-16s %s\n", $$1, $$2}'

build: ## Build a dev binary with embedded postgres support (-tags embed_pg).
	@mkdir -p $(dir $(BIN))
	go build -tags $(TAGS_DEV) -o $(BIN) ./cmd/{{.ProjectName}}
	@echo "→ $(BIN) (dev binary, embeds postgres ~50 MB)"

build-prod: ## Build a production binary (no embedded postgres, slim).
	@mkdir -p $(dir $(BIN_PROD))
	go build -trimpath -ldflags="-s -w" -o $(BIN_PROD) ./cmd/{{.ProjectName}}
	@echo "→ $(BIN_PROD) (production binary, connect via RAILBASE_DSN)"

dev: build ## Run with embedded postgres (downloads PG on first run; ~50 MB cached under pb_data/postgres/).
	RAILBASE_EMBED_POSTGRES=true \
	RAILBASE_LOG_LEVEL=debug \
	RAILBASE_LOG_FORMAT=text \
	./$(BIN) serve

migrate-diff: build ## Diff DSL vs DB and print the migration SQL.
	RAILBASE_EMBED_POSTGRES=true \
	./$(BIN) migrate diff

migrate-up: build ## Apply pending migrations.
	RAILBASE_EMBED_POSTGRES=true \
	./$(BIN) migrate up

clean: ## Remove built binaries (keeps pb_data/ for cluster + secrets).
	rm -rf bin/
